# Database Configuration
DATABASE_URL=postgresql://surveil_user:surveil_pass@localhost/smart_surveil
USE_SQLITE=false
SQLITE_URL=sqlite:///./smart_surveil.db

# External Services (optional fallback)
KAGGLE_URL=https://your-kaggle-endpoint.com
ENABLE_LOCAL_INFERENCE=true
INVERT_LOCAL_INFERENCE_LABELS=false

# Application Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Optional: Ngrok URL for external access
# NGROK_URL=https://your-ngrok-url.ngrok-free.app